---
const ownProjects = [
  {
    title:       'krimamakler.de',
    description: 'Versicherungsmakler-Website für Hausverwaltungen in Berlin. Lead-Flow, Testimonials und Kontaktformular.',
    tags:        ['Astro', 'Tailwind CSS', 'TypeScript', 'Cloudflare'],
    href:        'https://krimamakler.de',
    status:      'live',
    initials:    'KM',
    accentFrom:  '#6366f1',
    accentTo:    '#818cf8',
  },
  {
    title:       'Autowäsche & Aufbereitung',
    description: 'Service-Website für professionelle Fahrzeugpflege – Autoaufbereitung, Ambientebeleuchtung, Taxi-Service und KFZ-Händler-Pakete.',
    tags:        ['Astro', 'Tailwind CSS', 'TypeScript', 'Cloudflare'],
    href:        null,
    status:      'soon',
    initials:    'AW',
    accentFrom:  '#6366f1',
    accentTo:    '#818cf8',
  },
] as const;

const typo3Projects = [
  {
    title:       'tourismus-nuernberg.de',
    description: 'Offizielle Tourismus-Website der Stadt Nürnberg. Mitentwicklung im Team bei einer Webagentur.',
    tags:        ['TYPO3', 'Fluid', 'TYPOScript', 'SCSS', 'SEO'],
    href:        'https://tourismus-nuernberg.de',
    initials:    'TN',
    accentFrom:  '#f59e0b',
    accentTo:    '#ef4444',
  },
  {
    title:       'burg-rabenstein.de',
    description: 'Website für Burg Rabenstein – Tourismus, Veranstaltungen und Übernachtungsangebote. Website-Launch koordiniert.',
    tags:        ['TYPO3', 'Fluid', 'TYPOScript', 'SCSS'],
    href:        'https://burg-rabenstein.de',
    initials:    'BR',
    accentFrom:  '#10b981',
    accentTo:    '#06b6d4',
  },
  {
    title:       'neustadt-aisch.de',
    description: 'Kommunale Website der Stadt Neustadt a.d. Aisch. Website-Launch von der Konzeption bis zur Auslieferung geleitet.',
    tags:        ['TYPO3', 'Fluid', 'TYPOScript', 'SCSS', 'SEO'],
    href:        'https://neustadt-aisch.de',
    initials:    'NA',
    accentFrom:  '#3b82f6',
    accentTo:    '#8b5cf6',
  },
  {
    title:       'eckstein-evangelisch.de',
    description: 'Website der Evangelisch-Lutherischen Kirchengemeinde Nürnberg. Mitentwicklung bei einer Webagentur.',
    tags:        ['TYPO3', 'Fluid', 'TYPOScript', 'SCSS'],
    href:        'https://eckstein-evangelisch.de',
    initials:    'EK',
    accentFrom:  '#6366f1',
    accentTo:    '#818cf8',
  },
] as const;
---

<section id="projects" class="py-28 md:py-36" style="background: linear-gradient(to bottom, transparent, rgba(22,25,41,0.5), transparent);">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <p class="font-mono text-xs tracking-[0.22em] uppercase mb-4" style="color: #6366f1;">Projekte</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold">Was ich gebaut habe</h2>
    </div>

    <!-- Own projects -->
    <div class="mb-12">
      <p class="font-mono text-xs tracking-widest uppercase mb-6 reveal" style="color: #7880b0;">
        ◈ Eigene Projekte
      </p>
      <div class="grid sm:grid-cols-2 gap-5">
        {ownProjects.map(({ title, description, tags, href, status, initials, accentFrom, accentTo }, i) => (
          <article
            class="card-glow rounded-2xl overflow-hidden flex flex-col reveal"
            style={`background: #161929; transition-delay: ${i * 0.1}s;`}
          >
            <div
              class="relative h-36 flex items-center justify-center overflow-hidden"
              style={`background: linear-gradient(135deg, ${accentFrom}14, ${accentTo}0a);`}
            >
              <div
                class="absolute inset-0 opacity-20"
                style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 28px 28px;"
                aria-hidden="true"
              ></div>
              <span
                class="font-extrabold text-6xl select-none opacity-15"
                style={`font-family: 'Space Grotesk', sans-serif; background: linear-gradient(135deg, ${accentFrom}, ${accentTo}); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;`}
                aria-hidden="true"
              >{initials}</span>
              {status === 'live' ? (
                <div class="absolute top-3 right-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-mono" style="background: rgba(16,185,129,0.12); color: #34d399; border: 1px solid rgba(16,185,129,0.25);">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></div>
                  Live
                </div>
              ) : (
                <div class="absolute top-3 right-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-mono" style="background: rgba(99,102,241,0.12); color: #818cf8; border: 1px solid rgba(99,102,241,0.25);">
                  ✦ Coming Soon
                </div>
              )}
            </div>
            <div class="p-5 flex flex-col flex-1">
              <h3 class="text-lg font-extrabold mb-1.5 text-text">{title}</h3>
              <p class="text-sm text-muted leading-relaxed mb-4 flex-1">{description}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                {tags.map(tag => (
                  <span class="text-xs font-mono px-2.5 py-1 rounded-lg" style="background: rgba(255,255,255,0.04); color: #7880b0; border: 1px solid rgba(255,255,255,0.07);">{tag}</span>
                ))}
              </div>
              {href ? (
                <a href={href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-semibold transition-colors w-fit" style="color: #818cf8;">
                  Website besuchen
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg>
                </a>
              ) : (
                <span class="text-sm text-muted font-mono italic">In Entwicklung …</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- TYPO3 projects -->
    <div>
      <p class="font-mono text-xs tracking-widest uppercase mb-6 reveal" style="color: #7880b0;">
        ◉ TYPO3 · Webagentur
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {typo3Projects.map(({ title, description, tags, href, initials, accentFrom, accentTo }, i) => (
          <article
            class="card-glow rounded-2xl overflow-hidden flex flex-col reveal"
            style={`background: #161929; transition-delay: ${i * 0.08}s;`}
          >
            <div
              class="relative h-24 flex items-center justify-center overflow-hidden"
              style={`background: linear-gradient(135deg, ${accentFrom}12, ${accentTo}08);`}
            >
              <span
                class="font-extrabold text-4xl select-none opacity-15"
                style={`font-family: 'Space Grotesk', sans-serif; background: linear-gradient(135deg, ${accentFrom}, ${accentTo}); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;`}
                aria-hidden="true"
              >{initials}</span>
            </div>
            <div class="p-4 flex flex-col flex-1">
              <h3 class="text-sm font-bold mb-1.5 text-text leading-snug">{title}</h3>
              <p class="text-xs text-muted leading-relaxed mb-3 flex-1">{description}</p>
              <div class="flex flex-wrap gap-1.5 mb-3">
                {tags.map(tag => (
                  <span class="text-[10px] font-mono px-2 py-0.5 rounded" style="background: rgba(255,255,255,0.04); color: #7880b0; border: 1px solid rgba(255,255,255,0.07);">{tag}</span>
                ))}
              </div>
              <a href={href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs font-semibold transition-colors w-fit" style="color: #818cf8;">
                Website ↗
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

  </div>
</section>
