---
---

<section id="contact" class="py-28 md:py-36 relative overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
  >
    <div
      class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full"
      style="background: radial-gradient(circle, rgba(99,102,241,0.09), transparent 70%); filter: blur(40px);"
    ></div>
  </div>

  <div class="relative z-10 max-w-xl mx-auto px-6 text-center">
    <div class="reveal">
      <p class="font-mono text-xs tracking-[0.22em] uppercase mb-4" style="color: #6366f1;">Kontakt</p>

      <h2
        class="text-4xl sm:text-5xl font-extrabold mb-6 gradient-text leading-tight"
      >
        Lass uns verbinden.
      </h2>

      <p class="text-muted text-lg mb-10 leading-relaxed">
        Du findest mich auf LinkedIn und GitHub.
      </p>

      <div class="flex justify-center gap-4">
        <a
          href="https://www.linkedin.com/in/alexej-boger-0a70a920a/"
          target="_blank"
          rel="noopener noreferrer"
          class="card-glow inline-flex items-center gap-2.5 px-6 py-3.5 rounded-xl text-sm font-semibold text-text hover:text-white transition-all duration-300 hover:scale-105"
          style="background: #161929;"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="color: #0a66c2;">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          LinkedIn
        </a>
        <a
          href="https://github.com/AlexejB114"
          target="_blank"
          rel="noopener noreferrer"
          class="card-glow inline-flex items-center gap-2.5 px-6 py-3.5 rounded-xl text-sm font-semibold text-text hover:text-white transition-all duration-300 hover:scale-105"
          style="background: #161929;"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>
