---
const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid #2a2a3a;" class="py-8">
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-center text-sm text-muted">
    <div class="flex items-center gap-2">
      <span
        class="font-mono font-bold"
        style="background: linear-gradient(135deg,#8b5cf6,#22d3ee); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;"
      >AB.</span>
      <span>© {year} Alexej Boger</span>
    </div>
  </div>
</footer>
