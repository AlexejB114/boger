---
const stats = [
  { value: '4+',   label: 'Jahre Erfahrung' },
  { value: '20+',  label: 'Projekte' },
  { value: '4',    label: 'Sprachen' },
  { value: 'B.Sc.', label: 'E-Commerce' },
];

const languages = [
  { lang: 'Deutsch',  level: 'Muttersprache' },
  { lang: 'Englisch', level: 'C1'             },
  { lang: 'Russisch', level: 'in Wort'        },
  { lang: 'Spanisch', level: 'A2 → B1'        },
];
---

<section id="about" class="py-28 md:py-36">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-14 lg:gap-24 items-center">

      <!-- Text -->
      <div class="reveal">
        <p
          class="font-mono text-xs tracking-[0.22em] uppercase mb-4"
          style="color: #6366f1;"
        >Über mich</p>

        <h2 class="text-3xl sm:text-4xl font-extrabold mb-6 leading-snug">
          Lösungsorientiert.<br />
          <span class="gradient-text">Von der Idee bis zur Auslieferung.</span>
        </h2>

        <div class="space-y-4 text-muted leading-relaxed text-[0.95rem]">
          <p>
            Ich bin Frontend-Entwickler mit einem Bachelor of Science in E-Commerce.
            Seit 2021 entwickle ich anspruchsvolle Webprojekte – von
            TYPO3-Tourismus&shy;plattformen bis hin zu modernen Astro-Websites.
          </p>
          <p>
            Im Agenturumfeld habe ich eigenständig Projekte von der Konzeption
            bis zur Auslieferung geleitet, Entwickler und Azubis mentoriert und bekannte
            Websites wie{' '}
            <a
              href="https://neustadt-aisch.de"
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors"
              style="color: #818cf8;"
            >neustadt-aisch.de</a>{' '}
            und{' '}
            <a
              href="https://burg-rabenstein.de"
              target="_blank"
              rel="noopener noreferrer"
              class="transition-colors"
              style="color: #818cf8;"
            >burg-rabenstein.de</a>{' '}
            mitentwickelt.
          </p>
          <p>
            Mein Antrieb: sauberer Code, gute UX und Interfaces, die Menschen wirklich
            gerne benutzen.
          </p>
        </div>

        <!-- Language badges -->
        <div class="flex flex-wrap gap-4 mt-8">
          {languages.map(({ lang, level }) => (
            <div
              class="card-glow rounded-lg px-4 py-2.5 text-center"
              style="background: rgba(99,102,241,0.06);"
            >
              <div class="text-sm font-semibold text-text">{lang}</div>
              <div class="text-xs text-muted font-mono mt-0.5">{level}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Stats grid -->
      <div class="reveal" style="transition-delay: 0.15s;">
        <div class="grid grid-cols-2 gap-4">
          {stats.map(({ value, label }, i) => (
            <div
              class="card-glow rounded-2xl p-6 text-center"
              style={`background: #161929; transition-delay: ${i * 0.07}s;`}
            >
              <div class="text-4xl font-extrabold mb-2 gradient-text">{value}</div>
              <div class="text-sm text-muted leading-snug">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
