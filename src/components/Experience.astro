---
const entries = [
  {
    type:    'work',
    period:  'Jul 2023 – Apr 2025',
    company: 'Webagentur',
    location:'',
    role:    'Front-End-Entwickler',
    bullets: [
      'Leitung von Projekten über die gesamte Prozesskette – von der Konzeption bis zur Auslieferung',
      'Koordination der Frontend-Entwicklung und Planung von Website-Launches (burg-rabenstein.de, neustadt-aisch.de)',
      'Mitentwicklung renommierter Tourismus- und Kommunalwebsites wie tourismus-nuernberg.de',
      'Mentoring von Entwicklern und Auszubildenden, Einarbeitung neuer Mitarbeiter',
      'SEO-Optimierung und Durchführung von TYPO3-Schulungen',
    ],
    tags: ['TYPO3', 'Fluid', 'TYPOScript', 'JavaScript', 'SCSS', 'Bootstrap', 'PHP', 'SEO'],
  },
  {
    type:    'work',
    period:  'Jan 2022 – Mär 2023',
    company: 'Webagentur',
    location:'',
    role:    'Werkstudent Frontend Development',
    bullets: [
      'Shopware-Entwicklung und -Optimierung für Kunden',
      'Anpassung und Wartung von WordPress-Websites',
      'Optimierung von Websites und E-Commerce-Shopsystemen',
      'Betreuung und Beratung von Neu- und Bestandskunden',
    ],
    tags: ['Shopware', 'WordPress', 'HTML / CSS', 'Bootstrap', 'Twig', 'Git', 'SEO'],
  },
  {
    type:    'education',
    period:  '2019 – 2023',
    company: 'Hochschule',
    location:'',
    role:    'Bachelor of Science – E-Commerce',
    bullets: [
      'Schwerpunkte: Web-Programmierung, Oberflächengestaltung & Usability, Mobile Systeme',
      'Vertiefung: Conversion-Optimierung, Landing-Page-Optimierung, Nutzerforschung',
      'Bachelorarbeit: „Vergleich der Plugin-Schnittstellen von Shopware 5 und 6" – Note 1,3',
    ],
    tags: ['E-Commerce', 'Web-Programmierung', 'Shopware', 'UX / UI', 'SEO', 'IT-Projektmanagement'],
  },
] as const;
---

<section id="experience" class="exp-section">

  <div class="exp-bg" aria-hidden="true">
    <span class="exp-line dl0"></span>
    <span class="exp-line dl1"></span>
    <span class="exp-line dl2"></span>
    <span class="exp-line dl3"></span>
    <span class="exp-line dl4"></span>
    <span class="exp-line dl5"></span>
  </div>

  <div class="exp-glow" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto px-6 exp-inner">

    <div class="text-center mb-20 reveal">
      <p class="font-mono text-xs tracking-[0.22em] uppercase mb-4" style="color:#6366f1;">Werdegang</p>
      <h2 class="text-4xl sm:text-5xl font-extrabold italic gradient-text">Mein Weg.</h2>
    </div>

    <div class="exp-grid">
      {entries.map((entry, i) => (
        <div
          class={`exp-wrap ${i % 2 === 0 ? 'exp-left' : 'exp-right'}`}
          data-exp
        >
          <div class="exp-card card-glow" style="background: rgba(22,25,41,0.97);">

            <div class="exp-card-head">
              <span class="exp-num gradient-text">0{i + 1}</span>
              <span class="exp-pill">
                {entry.type === 'education' ? '🎓' : '💼'} {entry.period}
              </span>
            </div>

            <div class="gradient-text text-xl font-extrabold mb-1 leading-snug">{entry.company}</div>
            <div class="text-sm font-semibold mb-1" style="color:#f4f6ff;">{entry.role}</div>
            {entry.location && (
              <div class="font-mono text-xs mb-5" style="color:#9ba3c8;">{entry.location}</div>
            )}

            <ul class="exp-bullets">
              {entry.bullets.map(b => (
                <li>
                  <span class="exp-arrow" aria-hidden="true">▸</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            <div class="exp-tags">
              {entry.tags.map(tag => (
                <span class="exp-tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ── Section shell ── */
  .exp-section {
    position: relative;
    overflow: hidden;
    padding-top: 7rem;
    padding-bottom: 7rem;
  }
  @media (min-width: 768px) {
    .exp-section { padding-top: 9rem; padding-bottom: 9rem; }
  }

  /* ── Background lines ── */
  .exp-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    justify-content: space-around;
    z-index: 0;
  }
  .exp-line {
    width: 1px;
    height: 200%;
    margin-top: -50%;
  }
  .dl0 { background: linear-gradient(to bottom, transparent, rgba(99,102,241,0.18) 40%, rgba(99,102,241,0.26) 55%, rgba(99,102,241,0.18) 70%, transparent); animation: expDrift0 7s ease-in-out infinite; }
  .dl1 { background: linear-gradient(to bottom, transparent 10%, rgba(129,140,248,0.10) 42%, rgba(129,140,248,0.18) 58%, rgba(129,140,248,0.10) 74%, transparent); animation: expDrift1 9s ease-in-out infinite; }
  .dl2 { background: linear-gradient(to bottom, transparent, rgba(99,102,241,0.10) 38%, rgba(99,102,241,0.17) 56%, rgba(99,102,241,0.10) 72%, transparent); animation: expDrift2 11s ease-in-out infinite; }
  .dl3 { background: linear-gradient(to bottom, transparent 15%, rgba(129,140,248,0.09) 44%, rgba(129,140,248,0.16) 60%, rgba(129,140,248,0.09) 76%, transparent); animation: expDrift3 8s ease-in-out infinite 1s; }
  .dl4 { background: linear-gradient(to bottom, transparent, rgba(99,102,241,0.14) 40%, rgba(99,102,241,0.22) 57%, rgba(99,102,241,0.14) 73%, transparent); animation: expDrift4 13s ease-in-out infinite 0.5s; }
  .dl5 { background: linear-gradient(to bottom, transparent 20%, rgba(129,140,248,0.08) 46%, rgba(129,140,248,0.14) 62%, rgba(129,140,248,0.08) 78%, transparent); animation: expDrift5 10s ease-in-out infinite 2s; }

  @keyframes expDrift0 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(22px)} }
  @keyframes expDrift1 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(36px)} }
  @keyframes expDrift2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(14px)} }
  @keyframes expDrift3 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(28px)} }
  @keyframes expDrift4 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(10px)} }
  @keyframes expDrift5 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(24px)} }

  /* ── Radial background glow ── */
  .exp-glow {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,0.05) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .exp-inner { position: relative; z-index: 1; }

  /* ── Staggered grid ── */
  .exp-grid {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .exp-wrap {
    width: 60%;
    opacity: 0;
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .exp-left  { align-self: flex-start; transform: translateX(-60px); }
  .exp-right { align-self: flex-end;   transform: translateX( 60px); }
  .exp-wrap.visible { opacity: 1; transform: translateX(0); }

  @media (max-width: 767px) {
    .exp-wrap { width: 100%; }
    .exp-left  { transform: translateY(40px); }
    .exp-right { transform: translateY(40px); }
  }

  /* ── Card internals ── */
  .exp-card {
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 0 40px rgba(99,102,241,0.07);
  }
  .exp-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }
  .exp-num {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    opacity: 0.28;
  }
  .exp-pill {
    font-size: 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    color: #6366f1;
    background: rgba(99,102,241,0.08);
    border: 1px solid rgba(99,102,241,0.22);
    padding: 3px 10px;
    border-radius: 99px;
    white-space: nowrap;
  }
  .exp-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .exp-bullets li {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #9ba3c8;
    line-height: 1.5;
  }
  .exp-arrow {
    color: #6366f1;
    flex-shrink: 0;
    margin-top: 0.1em;
  }
  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .exp-tag {
    font-size: 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    padding: 2px 8px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    color: #9ba3c8;
    border-radius: 4px;
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('visible');
        io.unobserve(e.target);
      }
    }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('[data-exp]').forEach(el => io.observe(el));

  const lines = document.querySelectorAll<HTMLElement>('.exp-line');
  const speeds = [0.04, 0.09, 0.06, 0.11, 0.03, 0.07];
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    lines.forEach((line, i) => {
      line.style.setProperty('--scroll-y', `${Math.round(y * speeds[i])}px`);
    });
  }, { passive: true });
</script>
