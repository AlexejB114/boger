---
const entries = [
  {
    type:    'work',
    period:  'Jul 2023 – Apr 2025',
    company: 'Decide Internet Services',
    location:'Bad Windsheim',
    role:    'Front-End-Entwickler',
    bullets: [
      'Leitung von Projekten über die gesamte Prozesskette – von der Konzeption bis zur Auslieferung',
      'Koordination der Frontend-Entwicklung und Planung von Website-Launches (burg-rabenstein.de, neustadt-aisch.de)',
      'Mitentwicklung renommierter Tourismus- und Kommunalwebsites wie tourismus-nuernberg.de',
      'Mentoring von Entwicklern und Auszubildenden, Einarbeitung neuer Mitarbeiter',
      'SEO-Optimierung und Durchführung von TYPO3-Schulungen',
    ],
    tags: ['TYPO3', 'Fluid', 'TYPOScript', 'JavaScript', 'SCSS', 'Bootstrap', 'PHP', 'SEO'],
  },
  {
    type:    'work',
    period:  'Jan 2022 – Mär 2023',
    company: 'Nimbits GmbH',
    location:'Würzburg',
    role:    'Werkstudent Frontend Development',
    bullets: [
      'Shopware-Entwicklung und -Optimierung für Kunden',
      'Anpassung und Wartung von WordPress-Websites',
      'Optimierung von Websites und E-Commerce-Shopsystemen',
      'Betreuung und Beratung von Neu- und Bestandskunden',
    ],
    tags: ['Shopware', 'WordPress', 'HTML / CSS', 'Bootstrap', 'Twig', 'Git', 'SEO'],
  },
  {
    type:    'education',
    period:  '2019 – 2023',
    company: 'THWS Würzburg-Schweinfurt',
    location:'Würzburg',
    role:    'Bachelor of Science – E-Commerce',
    bullets: [
      'Schwerpunkte: Web-Programmierung, Oberflächengestaltung & Usability, Mobile Systeme',
      'Vertiefung: Conversion-Optimierung, Landing-Page-Optimierung, Nutzerforschung',
      'Bachelorarbeit: „Vergleich der Plugin-Schnittstellen von Shopware 5 und 6" – Note 1,3',
    ],
    tags: ['E-Commerce', 'Web-Programmierung', 'Shopware', 'UX / UI', 'SEO', 'IT-Projektmanagement'],
  },
] as const;
---

<section id="experience" class="py-28 md:py-36">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <p class="font-mono text-xs tracking-[0.22em] uppercase mb-4" style="color: #8b5cf6;">Werdegang</p>
      <h2 class="text-3xl sm:text-4xl font-extrabold">Mein Weg</h2>
    </div>

    <!-- Timeline -->
    <div class="relative">

      <!-- Vertical line -->
      <div
        class="absolute left-5 md:left-7 top-0 bottom-0 w-px"
        style="background: linear-gradient(to bottom, rgba(139,92,246,0.6), rgba(34,211,238,0.3), transparent);"
        aria-hidden="true"
      ></div>

      <div class="space-y-10">
        {entries.map((entry, i) => (
          <div
            class="reveal relative pl-14 md:pl-20"
            style={`transition-delay: ${i * 0.12}s;`}
          >
            <!-- Timeline dot -->
            <div
              class="absolute left-[13px] md:left-[19px] top-6 w-5 h-5 md:w-6 md:h-6 rounded-full border-2 flex items-center justify-center"
              style="background: #09090b; border-color: #8b5cf6; z-index: 1;"
              aria-hidden="true"
            >
              <div
                class="w-2 h-2 rounded-full"
                style="background: linear-gradient(135deg, #8b5cf6, #22d3ee);"
              ></div>
              {i === 0 && (
                <div
                  class="animate-ping-dot absolute inset-0 rounded-full"
                  style="background: rgba(139,92,246,0.4);"
                ></div>
              )}
            </div>

            <!-- Card -->
            <div class="card-glow rounded-2xl p-6" style="background: #13131a;">
              <!-- Period + type badge -->
              <div class="flex flex-wrap items-center gap-3 mb-3">
                <span
                  class="inline-flex items-center gap-1.5 font-mono text-xs px-3 py-1 rounded-full"
                  style="color: #8b5cf6; background: rgba(139,92,246,0.08); border: 1px solid rgba(139,92,246,0.2);"
                >
                  {entry.type === 'education' ? '🎓' : '💼'}
                  {entry.period}
                </span>
                <span class="text-xs text-muted font-mono">{entry.location}</span>
              </div>

              <div class="gradient-text text-xl font-extrabold mb-1">{entry.company}</div>
              <div class="text-sm font-semibold text-text mb-4">{entry.role}</div>

              <ul class="space-y-2 mb-5">
                {entry.bullets.map(bullet => (
                  <li class="flex gap-2 text-sm text-muted leading-relaxed">
                    <span style="color: #8b5cf6; flex-shrink: 0; margin-top: 0.15em;" aria-hidden="true">▸</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2">
                {entry.tags.map(tag => (
                  <span
                    class="text-xs font-mono px-2.5 py-1 rounded-md"
                    style="background: rgba(255,255,255,0.04); color: #7c7c99; border: 1px solid rgba(255,255,255,0.07);"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
