---
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-4">
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">

    <!-- Logo -->
    <a href="#top" class="flex items-center gap-2 group" aria-label="Alexej Boger – Startseite">
      <span
        class="font-mono text-lg font-bold"
        style="background: linear-gradient(135deg,#8b5cf6,#22d3ee); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;"
      >AB.</span>
      <span class="text-sm text-muted hidden sm:block transition-colors group-hover:text-text">
        Alexej Boger
      </span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-7" role="navigation" aria-label="Hauptnavigation">
      <a href="#about"      class="text-sm text-muted hover:text-text transition-colors">Über mich</a>
      <a href="#skills"     class="text-sm text-muted hover:text-text transition-colors">Skills</a>
      <a href="#experience" class="text-sm text-muted hover:text-text transition-colors">Werdegang</a>
      <a href="#projects"   class="text-sm text-muted hover:text-text transition-colors">Projekte</a>
    </div>

    <!-- Right: social icons -->
    <div class="flex items-center gap-2">
      <a
        href="https://www.linkedin.com/in/alexej-boger-0a70a920a/"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center p-2 rounded-lg text-muted hover:text-text transition-colors"
        aria-label="LinkedIn Profil"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
      <a
        href="https://github.com/AlexejB114"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:flex items-center p-2 rounded-lg text-muted hover:text-text transition-colors"
        aria-label="GitHub Profil"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="nav-toggle"
        class="md:hidden p-2 text-muted hover:text-text transition-colors"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <svg id="icon-open"  width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="display:none;">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="nav-menu"
    role="navigation"
    aria-label="Mobile Navigation"
    style="background: #13131a; border-top: 1px solid #2a2a3a;"
  >
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col gap-5">
      <a href="#about"      class="text-sm text-muted hover:text-text transition-colors">Über mich</a>
      <a href="#skills"     class="text-sm text-muted hover:text-text transition-colors">Skills</a>
      <a href="#experience" class="text-sm text-muted hover:text-text transition-colors">Werdegang</a>
      <a href="#projects"   class="text-sm text-muted hover:text-text transition-colors">Projekte</a>
      <div class="flex gap-4 pt-1">
        <a href="https://www.linkedin.com/in/alexej-boger-0a70a920a/" target="_blank" rel="noopener noreferrer" class="text-sm text-muted hover:text-text transition-colors">LinkedIn</a>
        <a href="https://github.com/AlexejB114" target="_blank" rel="noopener noreferrer" class="text-sm text-muted hover:text-text transition-colors">GitHub</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle   = document.getElementById('nav-toggle')!;
  const menu     = document.getElementById('nav-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    const next = !open;
    toggle.setAttribute('aria-expanded', String(next));
    menu.style.maxHeight = next ? menu.scrollHeight + 'px' : '0';
    (iconOpen  as HTMLElement).style.display = next ? 'none'  : '';
    (iconClose as HTMLElement).style.display = next ? ''      : 'none';
  });

  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.style.maxHeight = '0';
      (iconOpen  as HTMLElement).style.display = '';
      (iconClose as HTMLElement).style.display = 'none';
    });
  });
</script>
