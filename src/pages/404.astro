---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 – Seite nicht gefunden | Alexej Boger" description="Diese Seite existiert nicht.">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <p class="font-mono text-xs tracking-[0.22em] uppercase mb-4" style="color: #8b5cf6;">404</p>
    <h1 class="text-5xl sm:text-7xl font-extrabold mb-4 gradient-text">Nicht gefunden</h1>
    <p class="text-muted text-lg mb-10 max-w-md">
      Diese Seite existiert nicht – oder wurde verschoben.
    </p>
    <a
      href="https://boger.io/"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all"
      style="background: linear-gradient(135deg, #8b5cf6, #22d3ee); color: #09090b;"
    >
      Zurück zur Startseite
    </a>
  </main>
</Layout>
