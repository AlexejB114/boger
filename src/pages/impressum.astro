---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Impressum – Alexej Boger" description="Impressum von Alexej Boger, boger.io">
  <main class="max-w-2xl mx-auto px-6 py-28 min-h-screen">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-muted hover:text-text transition-colors mb-10 font-mono"
    >
      ← Zurück
    </a>

    <h1 class="text-3xl font-extrabold mb-8 gradient-text">Impressum</h1>

    <div class="space-y-6 text-muted text-[0.95rem] leading-relaxed">
      <section>
        <h2 class="text-text font-semibold mb-2">Angaben gemäß § 5 TMG</h2>
        <p>
          Alexej Boger<br />
          Stellergasse 6<br />
          91438 Bad Windsheim
        </p>
      </section>

      <section>
        <h2 class="text-text font-semibold mb-2">Kontakt</h2>
        <p>
          Telefon: <a href="tel:+4917134228059" class="text-accent-light hover:underline">0171 3422805</a><br />
          E-Mail: <a href="mailto:alexej@boger.io" class="text-accent-light hover:underline">alexej@boger.io</a>
        </p>
      </section>

      <section>
        <h2 class="text-text font-semibold mb-2">Haftungsausschluss</h2>
        <p>
          Die Inhalte dieser Website wurden mit größtmöglicher Sorgfalt erstellt.
          Für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte wird keine
          Gewähr übernommen.
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
